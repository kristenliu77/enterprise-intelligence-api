# Application
APP_NAME="Enterprise Intelligence API"
APP_VERSION="0.1.0"
APP_ENV="development"
DEBUG=false

# Redis / Celery
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"

# Tianyancha Open Platform
TIANYANCHA_API_KEY=""
TIANYANCHA_BASE_URL="https://open.api.tianyancha.com"

# BOSS Zhipin placeholder API config
BOSS_ZHIPIN_API_KEY=""
BOSS_ZHIPIN_BASE_URL="https://api.zhipin.com"

# Patsnap Open API
PATSNAP_API_KEY=""
PATSNAP_SECRET=""
PATSNAP_BASE_URL="https://api.patsnap.com"
PATSNAP_PATENT_SEARCH_PATH="/v1/patent-search"

# Xiniu / Xenniu funding data
XENNIU_API_TOKEN=""
XINIU_API_KEY=""
XINIU_BASE_URL="https://api.xiniudata.com"
XENNIU_BASE_URL="https://api.xiniudata.com"
XINIU_FUNDING_PATH="/openapi/company/funding-events"
XENNIU_FUNDING_PATH="/openapi/company/funding-events"

# Policy library placeholder
POLICY_LIBRARY_API_KEY=""
POLICY_LIBRARY_BASE_URL="https://api.policy.local"

# Free exchange-rate API used by funding amount normalization.
EXCHANGE_RATE_API_URL="https://open.er-api.com/v6/latest/{currency}"

# Comma-separated string or JSON array.
MONITORED_COMPANIES="腾讯科技有限公司,小米科技有限责任公司,武汉华工激光工程有限责任公司"

# JSON output path for scheduled hotness refresh.
HOTNESS_RESULTS_FILE="hotness_scores.json"
